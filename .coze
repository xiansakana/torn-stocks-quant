[project]
sub_id = "7f2e1a3b"
name = "torn-stocks-quant"
requires = ["nodejs-24"]
project_type = "web"
entrypoint = "dist/server.js"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "./scripts/prepare.sh"]
run = ["bash", "./scripts/dev.sh"]

[deploy]
build = ["bash", "./scripts/build.sh"]
run = ["bash", "./scripts/start.sh"]

[deploy.profile]
kind = "service"
flavor = "web"

[subprojects]
path = ["."]
